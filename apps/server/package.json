{
  "name": "@bankops/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "HOST=127.0.0.1 node --import tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_ENV=production node dist/main.js",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bankops/audit-log-model": "workspace:*",
    "@bankops/contracts": "workspace:*",
    "@bankops/ops-tape-sim": "workspace:*",
    "@fastify/static": "8.3.0",
    "@fastify/websocket": "11.2.0",
    "fastify": "5.6.2"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "tsx": "4.21.0",
    "vitest": "4.1.5",
    "ws": "8.20.0"
  }
}
