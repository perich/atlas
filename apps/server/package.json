{
  "name": "@bankops/server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "HOST=127.0.0.1 node --conditions=development --import tsx src/main.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "NODE_ENV=production node dist/main.js",
    "test": "NODE_OPTIONS=--conditions=development vitest",
    "test:run": "NODE_OPTIONS=--conditions=development vitest run",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@bankops/analyst-model": "workspace:*",
    "@bankops/audit-log-model": "workspace:*",
    "@bankops/contracts": "workspace:*",
    "@bankops/ops-tape-sim": "workspace:*",
    "@fastify/static": "8.3.0",
    "@fastify/websocket": "11.2.0",
    "@tanstack/ai": "0.18.0",
    "@tanstack/ai-code-mode": "0.1.12",
    "@tanstack/ai-isolate-node": "0.1.12",
    "@tanstack/ai-isolate-quickjs": "0.1.12",
    "@tanstack/ai-openrouter": "0.9.1",
    "fastify": "5.6.2",
    "isolated-vm": "6.1.2",
    "quickjs-emscripten": "0.32.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@types/ws": "8.18.1",
    "tsx": "4.21.0",
    "vitest": "4.1.5",
    "ws": "8.20.0"
  }
}
