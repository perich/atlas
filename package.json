{
  "name": "bankops-mission-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "prepare": "husky",
    "dev": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:scan": "concurrently -n web,server -c cyan,green \"pnpm --filter @bankops/web dev:scan\" \"pnpm dev:server\"",
    "dev:web": "pnpm --filter @bankops/web dev",
    "dev:server": "pnpm --filter @bankops/server dev",
    "build": "pnpm -r --if-present build",
    "start": "pnpm --filter @bankops/server start",
    "preview:web": "pnpm --filter @bankops/web preview",
    "doctor": "react-doctor . --verbose",
    "doctor:diff": "react-doctor . --verbose --diff",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "precommit": "pnpm lint-staged && pnpm test:docs && pnpm test:sherif && pnpm test:knip && pnpm typecheck && pnpm lint && pnpm test:run && pnpm format:check",
    "test:docs": "node scripts/verify-local-links.mjs",
    "test:sherif": "sherif",
    "test:knip": "knip --treat-config-hints-as-errors",
    "lint-staged": "lint-staged",
    "test": "pnpm -r --if-present test",
    "test:run": "pnpm -r --if-present test:run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.2",
    "concurrently": "9.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.10.1",
    "husky": "^9.1.7",
    "knip": "6.14.1",
    "lint-staged": "^16.4.0",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "react-doctor": "0.1.6",
    "sherif": "1.11.1",
    "typescript": "6.0.3"
  },
  "lint-staged": {
    "*.{js,jsx,mjs,ts,tsx,json,jsonc,css,md,mdx}": "oxfmt --write --no-error-on-unmatched-pattern"
  },
  "engines": {
    "node": "24.x"
  },
  "packageManager": "pnpm@11.1.0"
}
