{
  "name": "bankops-mission-control",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "concurrently -n web,server -c cyan,green \"pnpm dev:web\" \"pnpm dev:server\"",
    "dev:web": "pnpm --filter @bankops/web dev",
    "dev:server": "pnpm --filter @bankops/server dev",
    "build": "pnpm -r --if-present build",
    "preview:web": "pnpm --filter @bankops/web preview",
    "typecheck": "pnpm -r --if-present typecheck",
    "lint": "oxlint --type-aware .",
    "format": "oxfmt --write .",
    "format:check": "oxfmt --check .",
    "test": "pnpm -r --if-present test",
    "test:run": "pnpm -r --if-present test:run",
    "test:e2e": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@types/node": "25.6.2",
    "concurrently": "9.2.1",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-you-might-not-need-an-effect": "0.10.1",
    "oxfmt": "0.48.0",
    "oxlint": "1.63.0",
    "oxlint-tsgolint": "0.22.1",
    "typescript": "6.0.3"
  },
  "engines": {
    "node": ">=22.13"
  },
  "packageManager": "pnpm@11.1.0"
}
